PROJECT_NAME=Socrat
ENVIRONMENT=development

# PostgreSQL connection string used by the backend.
# Host/port/credentials must match the docker-compose Postgres service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/socrat

# Credentials for the Postgres container (read by docker-compose).
# Defaults are for local development only — change them for any real deployment.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=socrat

# Google Gemini API key. Get one from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
